# Port prefix (2-digit). All services use ports {PREFIX}00 through {PREFIX}12.
# Default: 30 (ports 3000-3012). Worktrees get unique prefixes automatically.
PORT_PREFIX=30

# Database
DATABASE_URL=postgres://openslaq:openslaq@localhost:3002/openslaq

# Auth mode: "stack-auth" (default, requires Stack Auth config below) or "builtin" (email/password)
AUTH_MODE=stack-auth
# AUTH_JWT_SECRET=  # required when AUTH_MODE=builtin — secret for signing JWTs
# SERVER_NAME=OpenSlaq  # display name for this instance (shown in mobile app)

# Stack Auth (required when AUTH_MODE=stack-auth)
VITE_STACK_PROJECT_ID=924565c5-6377-44b7-aa75-6b7de8d311f4
VITE_STACK_PUBLISHABLE_CLIENT_KEY=pck_mzrc4yyt8zgpzxcnysj55e7s6365ebs5rrtg6v14cfvrr
# STACK_SECRET_SERVER_KEY=  # optional — only needed for admin impersonation

# API
API_PORT=3001
API_ARTIFICIAL_DELAY_MS=0
CORS_ORIGIN=http://localhost:3000,http://tauri.localhost,http://localhost:3007

# S3 (Bun reads S3_* env vars automatically)
S3_ENDPOINT=http://localhost:3003
S3_REGION=us-east-1
S3_BUCKET=openslaq-uploads
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
# S3_PUBLIC_ENDPOINT=  # public-facing S3 endpoint for presigned URLs (defaults to S3_ENDPOINT; set to http://<LAN_IP>:3003 for iOS simulator)

# LiveKit
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_API_URL=http://localhost:3004
LIVEKIT_WS_URL=ws://localhost:3004
# LIVEKIT_PUBLIC_WS_URL=  # public-facing LiveKit WS URL returned to clients (defaults to LIVEKIT_WS_URL)

# Admin
ADMIN_USER_IDS=

# Frontend
VITE_API_URL=http://localhost:3001
# VITE_APPLE_TEAM_ID=  # 10-char Apple Developer Team ID — enables iOS Universal Links
# VITE_APPLE_APP_ID=   # App Store ID (numeric) — enables Smart App Banner on invite pages
OPENSLAQ_WEB_URL=http://localhost:3000
VITE_LIVEKIT_WS_URL=ws://localhost:3004

# Mobile (Expo requires EXPO_PUBLIC_ prefix)
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_WEB_URL=http://localhost:3000
EXPO_PUBLIC_STACK_PROJECT_ID=924565c5-6377-44b7-aa75-6b7de8d311f4
EXPO_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=pck_mzrc4yyt8zgpzxcnysj55e7s6365ebs5rrtg6v14cfvrr
EXPO_PUBLIC_E2E_TEST_SECRET=openslaq-e2e-test-secret-do-not-use-in-prod

# Linear integration (optional)
# LINEAR_CLIENT_ID=
# LINEAR_CLIENT_SECRET=
# LINEAR_WEBHOOK_SECRET=

# Sentry integration (optional)
# SENTRY_CLIENT_ID=
# SENTRY_CLIENT_SECRET=
# SENTRY_WEBHOOK_SECRET=
# SENTRY_APP_SLUG=

# Vercel integration (optional)
# VERCEL_CLIENT_ID=
# VERCEL_CLIENT_SECRET=
# VERCEL_WEBHOOK_SECRET=

# Bugsink / Sentry error tracking
SENTRY_DSN=http://key@localhost:3012/1
VITE_SENTRY_DSN=http://key@localhost:3012/2
EXPO_PUBLIC_SENTRY_DSN=http://key@localhost:3012/3
