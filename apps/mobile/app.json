{
  "expo": {
    "name": "OpenSlaq",
    "slug": "openslaq",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "scheme": "openslaq",
    "platforms": [
      "ios"
    ],
    "ios": {
      "bundleIdentifier": "com.openslaq.mobile",
      "supportsTablet": true,
      "icon": "./assets/icon.png",
      "infoPlist": {
        "UIBackgroundModes": ["audio", "remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1264a3"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-web-browser",
      "expo-apple-authentication",
      "expo-notifications",
      "@config-plugins/react-native-webrtc"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "web": {
      "bundler": "metro"
    }
  }
}
