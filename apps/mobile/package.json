{
  "name": "@openslaq/mobile",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "ios": "APP_VARIANT=development expo run:ios",
    "ios:device": "APP_VARIANT=development expo run:ios --device --no-bundler",
    "ios:device:metro": "lsof -ti :8081 | xargs kill -9 2>/dev/null; APP_VARIANT=development EXPO_PUBLIC_API_URL=https://tunnel.qual.dev expo start",
    "ios:device:release": "EXPO_PUBLIC_API_URL=https://tunnel.qual.dev expo run:ios --device --configuration Release",
    "android": "expo run:android",
    "lint": "eslint .",
    "typecheck": "tsgo --noEmit",
    "test": "NODE_OPTIONS='--require ./jest-bun-resolver.js' jest",
    "test:watch": "NODE_OPTIONS='--require ./jest-bun-resolver.js' jest --watch",
    "test:coverage": "NODE_OPTIONS='--require ./jest-bun-resolver.js' jest --coverage",
    "prebuild": "expo prebuild --platform ios --clean",
    "e2e:prebuild": "expo prebuild --platform ios --clean",
    "e2e:build": "detox build --configuration ios.sim.release",
    "e2e:test": "detox test --configuration ios.sim.release"
  },
  "dependencies": {
    "@config-plugins/react-native-webrtc": "^13.0.0",
    "@livekit/react-native": "^2.9.6",
    "@openslaq/client-core": "workspace:*",
    "@openslaq/editor": "workspace:*",
    "@openslaq/shared": "workspace:*",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@ronradtke/react-native-markdown-display": "^8.1.0",
    "@sentry/react-native": "^8.4.0",
    "expo": "~54.0.0",
    "expo-apple-authentication": "^8.0.8",
    "expo-asset": "~12.0.12",
    "expo-auth-session": "~7.0.10",
    "expo-av": "^16.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-crypto": "~15.0.8",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-keep-awake": "~15.0.8",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.0",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "hono": "^4.7.4",
    "livekit-client": "^2.17.2",
    "lucide-react-native": "^0.577.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-image-viewing": "^0.2.2",
    "react-native-keyboard-controller": "^1.21.3",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-syntax-highlighter": "^2.1.0",
    "react-native-callkeep": "^4.3.16",
    "react-native-voip-push-notification": "^3.3.3",
    "react-native-webrtc": "^124.0.7",
    "react-native-webview": "^13.16.1",
    "rn-emoji-keyboard": "^1.7.0"
  },
  "devDependencies": {
    "@openslaq/rn-layout-testing": "workspace:*",
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/preset-typescript": "^7.25.0",
    "@eslint/js": "^10.0.1",
    "@jest/reporters": "^29.7.0",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "detox": "^20.29.0",
    "eslint": "9",
    "eslint-plugin-oxlint": "^1.56.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-react-native-a11y": "^3.5.1",
    "jest": "^29.7.0",
    "jest-circus": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jest-expo": "~54.0.17",
    "jose": "^6.0.0",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.7.3",
    "@config-plugins/react-native-callkeep": "^12.0.0",
    "typescript-eslint": "^8.57.1"
  }
}
