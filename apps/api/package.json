{
  "name": "@openslaq/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./app": {
      "types": "./dist/app.d.ts",
      "default": "./src/app.ts"
    }
  },
  "scripts": {
    "dev": "bun --env-file=../../.env run --hot src/index.ts",
    "build:types": "tsgo --emitDeclarationOnly --noEmit false --outDir dist",
    "typecheck": "tsgo --noEmit",
    "db:generate": "bun --env-file=../../.env drizzle-kit generate",
    "db:migrate": "bun --env-file=../../.env run src/db/migrate.ts",
    "db:seed": "bun --env-file=../../.env run src/db/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@hono/zod-openapi": "^0.19.10",
    "@hono/zod-validator": "^0.4.3",
    "@openslaq/huddle": "workspace:*",
    "@openslaq/shared": "workspace:*",
    "@scalar/hono-api-reference": "^0.9.44",
    "@sentry/node": "^10.43.0",
    "@socket.io/postgres-adapter": "^0.5.0",
    "@stackframe/js": "^2.8.68",
    "drizzle-orm": "^0.38.4",
    "hono": "^4.7.4",
    "htmlparser2": "^10.1.0",
    "jose": "^6.0.8",
    "livekit-server-sdk": "^2.15.0",
    "pg": "^8.20.0",
    "postgres": "^3.4.5",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bun": "^1.2.4",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.30.4",
    "typescript": "^5.7.3"
  }
}
