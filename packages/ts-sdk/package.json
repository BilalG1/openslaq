{
  "name": "openslaq",
  "version": "0.1.0",
  "description": "TypeScript SDK for the OpenSlaq API",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "bun run --filter @openslaq/shared build:types && tsup",
    "test": "bun test",
    "typecheck": "tsgo --noEmit",
    "prepublishOnly": "bun run build"
  },
  "license": "MIT",
  "keywords": ["openslaq", "sdk", "api", "messaging"],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@openslaq/shared": "workspace:*",
    "@types/bun": "^1.3.9",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3"
  }
}
